# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Override root-level lib/ ignore (Python gitignore) — Next.js src/lib is source code
!src/lib/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mock data (API 연동 전까지만 사용)
src/lib/admin-mock-data.ts

# ─── OS ──────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ─── IDE / Editor ────────────────────────────
# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/

# Claude Code
.claude/

# VS Code
.vscode/
*.code-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
Session.vim
.netrwhist
tags

# Emacs
*~
\#*\#
.emacs.desktop
*.elc
auto-save-list
tramp
